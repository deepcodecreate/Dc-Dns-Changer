<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="?attr/colorPrimaryDark">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/servers_recyclerview"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false"/>
            
        <Space
            android:layout_width="match_parent"
            android:layout_height="12dp"/>
            
        <com.google.android.material.button.MaterialButton
            android:id="@+id/import_from_clipboard_button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:paddingVertical="12dp"
            android:text="Import from Clipboard"
            android:textColor="?attr/colorOnPrimary"
            android:backgroundTint="?attr/colorPrimary"
            app:icon="@drawable/ic_clip"
            app:rippleColor="@android:color/transparent"
            app:iconTint="?attr/colorAccent"
            app:cornerRadius="30dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/add_custom_server_button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:paddingVertical="12dp"
            android:text="Add Custom DNS"
            android:textColor="?attr/colorOnPrimary"
            android:backgroundTint="?attr/colorPrimary"
            app:icon="@drawable/ic_add"
            app:rippleColor="@android:color/transparent"
            app:iconTint="?attr/colorAccent"
            app:cornerRadius="30dp"/>
    </LinearLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
